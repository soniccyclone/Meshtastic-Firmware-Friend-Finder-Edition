__pycache__/
*.pyc

# Claude Code ephemeral runtime state.
.claude/scheduled_tasks.lock

# testbed/ — local Python venv for talking to flashed devices.
# Keep requirements.txt tracked; everything else is scratch.
testbed/.venv/
testbed/*.log
